# Cortex-Local Configuration
# Copy this file to .env and adjust values as needed.

# PostgreSQL
POSTGRES_USER=cortex
POSTGRES_PASSWORD=cortex_dev_password
POSTGRES_DB=cortex
POSTGRES_PORT=5433

# Embedding Model
EMBEDDING_MODEL_URL=http://nomic-embed:11435
EMBEDDING_MODEL_NAME=nomic-embed-text-v1.5
EMBEDDING_DIMENSIONS=768

# LLM
LLM_MODEL_URL=http://qwen:11434
LLM_MODEL_NAME=qwen3:8B-Q4_K_M

# MCP Servers
MCP_VECTOR_URL=http://mcp-vector:8001
MCP_GIT_URL=http://mcp-git:8002
MCP_TRANSCRIPT_URL=http://mcp-transcript:8003

# Gateway
GATEWAY_PORT=8000
GATEWAY_MAX_TOOL_ITERATIONS=5

# Ingestion
INGESTION_PORT=8004
INGESTION_BATCH_SIZE=32
INGESTION_CHUNK_SIZE=500
INGESTION_CHUNK_OVERLAP=50

# Web UI
WEB_UI_PORT=3000
GATEWAY_EXTERNAL_URL=http://localhost:8000
